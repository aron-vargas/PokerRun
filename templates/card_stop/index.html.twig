
{# templates/admin/custom.html.twig #}
{% extends '@EasyAdmin/page/content.html.twig' %}

{% block head_stylesheets %}
    {{ parent() }}
    <meta name="viewport" content="width=device-width, initial-scale=1.0, minimum-scale=1.0, maximum-scale=10.0, user-scalable=yes">
{% endblock %}

{% block content_title %}
    <div class="d-flex pb-1" style="border-bottom: 1px solid #3f3f3f;">
    {% if app.user and app.user.cardStop %}
        <span class='p-2'>
            Card Stop:
        </span>
        <span class="me-3 p-2 display-4" style='background-color: #fdf2e2'>
            <img class="me-2" src="{{ asset(app.user.cardStop.getLogo()) }}" style="height: 50px; width: auto;"/>
            {{ app.user.cardStop.getCardStopName() }}
        </span>
    {% else %}
        Main Street Fernley Card Stop
    {% endif %}
    </div>
{% endblock %}

{% block main %}
<style>
    .example-wrapper { margin: 1em auto; max-width: 100%; width: 95%; font: 18px/1.5 sans-serif; }
    .example-wrapper code { background: #F5F5F5; padding: 2px 6px; }
</style>

<div class="example-wrapper">
    <h1 class='title'>
        Player Checkins
        <small class="float-end">
            <a class="btn btn-primary btn-small p-2" href="{{ path('app_card_stop') }}"><i class="fa fa-refresh"></i></a>
        </small>
    </h1>
    <table class="table table-striped mb-6">
        <thead>
            <tr>
                <th>Player Name</th>
                <th>Check-in Time</th>
                <th>Location</th>
            </tr>
        </thead>
        <tbody>
            {% for location in pendingVerifications %}
                <tr>
                    <td>{{ location.firstName }} {{ location.lastName }}</td>
                    <td>{{ location.checkinTime|date('Y-m-d H:i:s') }}</td>
                    <td>{{ location.location }}</td>
                    <td>
                        <a class="btn btn-success" href="{{ path('cardstop_checkin_confirm', {'location_id': location.id, 'player_id': location.player_id}) }}">Confirm</a>
                        <a class="btn btn-danger" href="{{ path('cardstop_checkin_deny', {'location_id': location.id, 'player_id': location.player_id}) }}">Deny</a>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
