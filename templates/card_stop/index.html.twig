
{# templates/admin/custom.html.twig #}
{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}
    {% if user and user.cardStop %}
        Welcome to {{ user.cardStop.getCardStopName() }}
    {% else %}
        Main Street Fernley Card Stop
    {% endif %}
{% endblock %}

{% block main %}
<style>
    .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
    .example-wrapper code { background: #F5F5F5; padding: 2px 6px; }
</style>

<div class="example-wrapper">
    <h1 class='title'>Recent Player Activity</h1>
    <table class="table table-striped mb-6">
        <thead>
            <tr>
                <th>Player Name</th>
                <th>Check-in Time</th>
                <th>Location</th>
            </tr>
        </thead>
        <tbody>
            {% for location in pendingVerifications %}
                <tr>
                    <td>{{ location.firstName }} {{ location.lastName }}</td>
                    <td>{{ location.checkInTime|date('Y-m-d H:i:s') }}</td>
                    <td>{{ activity.location }}</td>
                    <td>
                        <a class="btn btn-success" href={{ path('checkin_confirm', ['location_id' => location.id, 'player_id' => location.player_id]) }}>Confirm</a>
                        <a class="btn btn-danger" href={{ path('checkin_deny', ['location_id' => location.id, 'player_id' => location.player_id]) }}>Deny</a>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
