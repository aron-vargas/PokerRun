{% extends '@EasyAdmin/page/content.html.twig' %}

{% block head_stylesheets %}
    {{ parent() }}
    <meta name="viewport" content="width=device-width, initial-scale=1.0, minimum-scale=1.0, maximum-scale=10.0, user-scalable=yes">
{% endblock %}

{% block content %}

<div class="content">
    {{ include('menus/adminbar.html.twig') }}
    <section class="content-header">
        <div class="content-header-title">
            <h1 class='title'>Dashboard Overview</h1>
        </div>
    </section>
    <section class="content-body">
        <!-- Dashboard Metric Grid Row -->
        <div class="row g-4 pb-4">
            <!-- Total Players -->
            <div class="col-12 col-sm-6 col-xl-3">
                <div class="card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-itemt-center mb-3">
                        <span class="text-muted fw-medium text-uppercase medium">Total Players</span>
                        <div class="bg-primary-subtle text-primary rounded px-2 py-1">
                            <i class="fa fa-people-group fs-5"></i>
                        </div>
                    </div>
                    <h3 class="mb-2 fw-bold">{{ totalPlayers }}</h3>
                </div>
                </div>
            </div>
            <!-- Total Check-ins -->
            <div class="col-12 col-sm-6 col-xl-3">
                <div class="card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-itemt-center mb-3">
                        <span class="text-muted fw-medium text-uppercase medium">Total Check-ins</span>
                        <div class="bg-primary-subtle text-primary rounded px-2 py-1">
                            <i class="fa fa-check-circle fs-5"></i>
                        </div>
                    </div>
                    <h3 class="mb-2 fw-bold">{{ totalCheckIns }}</h3>
                </div>
                </div>
            </div>
            <!-- Total Poker Cards -->
            <div class="col-12 col-sm-6 col-xl-3">
                <div class="card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-itemt-center mb-3">
                        <span class="text-muted fw-medium text-uppercase medium">Total Poker Cards</span>
                        <div class="bg-primary-subtle text-primary rounded px-2 py-1">
                            <i class="fa fa-layer-group fs-5"></i>
                        </div>
                    </div>
                    <h3 class="mb-2 fw-bold">{{ totalPokerCards }}</h3>
                </div>
                </div>
            </div>
        </div>

        <h1 class='title'>Recent Player Activity</h1>
        <table class="table table-striped mb-6">
            <thead>
                <tr>
                    <th>Player Name</th>
                    <th>Check-in Time</th>
                    <th>Location</th>
                </tr>
            </thead>
            <tbody>
                {% for activity in recentActivities %}
                    <tr>
                        <td>{{ activity.playerName }}</td>
                        <td>{{ activity.checkInTime|date('Y-m-d H:i:s') }}</td>
                        <td><span class="d-inline-flex align-items-center gap-2"><img src="{{ asset(activity.logo) }}" alt="{{ activity.location }}" style="height:32px;width:32px;object-fit:contain;" />{{ activity.location }}</span>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>

        <h1 class="title pt-4">Current Highest Poker Hands</h1>
        <table class="table table-striped mb-6">
            <thead>
                <tr>
                    <th>Player Name</th>
                    <th>Poker Hand</th>
                    <th>Hand Rank</th>
                </tr>
            </thead>
            <tbody>
                {% for hand in currentPokerHands %}
                    <tr>
                        <td>{{ hand.playerName }}</td>
                        <td>{{ hand.pokerHand }}</td>
                        <td>{{ hand.handRank }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </section>
</div>
{% endblock %}