{# templates/admin/custom.html.twig #}
{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}Main Street Fernley's Poker Run{% endblock %}

{% block main %}
    <div class="bg-secondary mb-2 px-2 d-flex">
        <a class="text-white" href="{{ path('app_welcome') }}">Poker Run</a>

    </div>

    {% if user.location and user.location.isVerified %}
        <div class="alert alert-success">
            <img class="me-2" src="{{ user.location.CardStop.logo }}" style="height: 50px; width: auto;"/>
            You are currently checked in at {{ user.location.CardStop.card_stop_name }}
        </div>
        {% if user.location.first_card %}
            <div class="alert alert-info">
                {% include 'player/card.html.twig' with { 'card': user.location.first_card } %}
            </div>
        {% else %}
            <div class="alert alert-info">
                <a href="{{ path('app_pick_card') }}" class="btn btn-primary">Pick Your Card</a>
            </div>
        {% endif %}
    {% elseif user.location and not user.location.isVerified %}
        <div class="alert alert-warning">
            <img class="me-2" src="{{ user.location.CardStop.logo }}" style="height: 50px; width: auto;"/>
            Your check-in at {{ user.location.CardStop.card_stop_name }} is pending verification. Please wait for a staff member to verify your check-in.
        </div>
    {% else %}
        <div class="alert alert-info">
            You are not currently checked in at any location.
            Please Check In at a card stop to participate in the Poker Run.
        </div>
    {% endif %}

    <!-- Display the user's poker hand if they have one -->
    <div class="container-fluid my-4">
        <h4 class="title">My Poker Hand:</h4>
        <div class="row gx-1">
            {% set card1No = '1' %}
            {% if user.pokerHand and user.pokerHand.cardOne %}
                {% set card1img = 'images/PlayingCards/' ~ user.pokerHand.cardOne.cardNumber ~ '_of_' ~ user.pokerHand.cardOne.cardSuit ~ '.png' %}
            {% else %}
                {% set card1img = 'images/PlayingCards/red-back.png' %}
            {% endif %}
            <div class="card poker-card">
                <div class="poker-card-body" style="background-image: url('{{ asset(card1img) }}');">
                   
                </div>
                <div class="pcf">
                    {{ card1No }}
                </div>
            </div>
            {% set card2No = '2' %}
            {% if user.pokerHand and user.pokerHand.cardTwo %}
                {% set card2img = 'images/PlayingCards/' ~ user.pokerHand.cardTwo.cardNumber ~ '_of_' ~ user.pokerHand.cardTwo.cardSuit ~ '.png' %}
            {% else %}
                {% set card2img = 'images/PlayingCards/red-back.png' %}
            {% endif %}
            <div class="card poker-card">
                <div class="poker-card-body" style="background-image: url('{{ asset(card2img) }}');">
                    
                </div>
                <div class="pcf">
                    {{ card2No }}
                </div>
            </div>
            {% set card3No = '3' %}
            {% if user.pokerHand and user.pokerHand.cardThree %}
                {% set card3img = 'images/PlayingCards/' ~ user.pokerHand.cardThree.cardNumber ~ '_of_' ~ user.pokerHand.cardThree.cardSuit ~ '.png' %}
            {% else %}
                {% set card3img = 'images/PlayingCards/red-back.png' %}
            {% endif %}
            <div class="card poker-card">
                <div class="poker-card-body" style="background-image: url('{{ asset(card3img) }}');">
                    
                </div>
                <div class="pcf">
                    {{ card3No }}
                </div>
            </div>
            {% set card4No = '4' %}
            {% if user.pokerHand and user.pokerHand.cardFour %}
                {% set card4img = 'images/PlayingCards/' ~ user.pokerHand.cardFour.cardNumber ~ '_of_' ~ user.pokerHand.cardFour.cardSuit ~ '.png' %}
            {% else %}
                {% set card4img = 'images/PlayingCards/red-back.png' %}
            {% endif %}
            <div class="card poker-card">
                <div class="poker-card-body" style="background-image: url('{{ asset(card4img) }}');">
                    
                </div>
                <div class="pcf">
                    {{ card4No }}
                </div>
            </div>
            {% set card5No = '5' %}
            {% if user.pokerHand and user.pokerHand.cardFive %}
                {% set card5img = 'images/PlayingCards/' ~ user.pokerHand.cardFive.cardNumber ~ '_of_' ~ user.pokerHand.cardFive.cardSuit ~ '.png' %}
            {% else %}
                {% set card5img = 'images/PlayingCards/red-back.png' %}
            {% endif %}
            <div class="card poker-card">
                <div class="poker-card-body" style="background-image: url('{{ asset(card5img) }}');">
                    
                </div>
                <div class="pcf">
                    {{ card5No }}
                </div>
            </div>
        </div>
    </div>
    <!-- Display the user's cards -->
    <div class="container-fluid my-4">
        <h4 class="title">All My Cards:</h4>
        <div class="row gx-1">
            {% if user.cardList|length > 0 %}
                {% for card in user.cardList %}
                    <div class="card poker-card">
                        <div class="poker-card-body">
                            {{ card.cardNumber }} of {{ card.cardSuit }} 
                        </div>
                    </div>
                {% endfor %}
            {% else %}
                <div class="card poker-card">
                    <div class="poker-card-body"> </div>
                    <div class="pcf">No cards picked yet.</div>
                </div>
            {% endif %}
            </ul>
        </div>
    </div>
{% endblock %}
