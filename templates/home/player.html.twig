{% extends "base.html.twig" %}

{% block title %}User Profile - {{ app.user.firstName }} {{ app.user.lastName }}{% endblock %}

{% block body %}
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-6">
                <!-- Profile Card -->
                <div class="card profile-card">
                    <!-- Header with gradient -->
                    <div class="profile-header">
                        <!-- Avatar -->
                        {% if app.user.avatar %}
                            <img src="{{ app.user.avatar }}" alt="Profile" class="profile-avatar">
                        {% else %}
                            <div class="profile-avatar" style="background-color: rgba(255,255,255,0.2); display: flex; align-items: center; justify-content: center; font-size: 60px;">
                                👤
                            </div>
                        {% endif %}
                    </div>

                    <!-- User Information -->
                    <div class="profile-info">
                        <!-- Name -->
                        <div class="profile-name">
                            {{ app.user.firstName }} {{ app.user.lastName }}
                        </div>

                        <!-- Email -->
                        <div class="profile-email">
                            <i class="bi bi-envelope"></i>
                            {{ app.user.email }}
                        </div>

                        <!-- Status Badges -->
                        <div class="profile-status">
                            {% if app.user.active %}
                                <span class="status-badge status-active">✓ Active</span>
                            {% else %}
                                <span class="status-badge status-inactive">Inactive</span>
                            {% endif %}

                            {% if app.user.isVerified %}
                                <span class="status-badge status-verified">✓ Verified</span>
                            {% else %}
                                <span class="status-badge status-inactive">Not Verified</span>
                            {% endif %}
                        </div>

                        <!-- Roles -->
                        {% if app.user.roles %}
                            <div class="profile-roles">
                                <strong>Roles:</strong><br>
                                {% for role in app.user.roles %}
                                    <span class="role-badge">{{ role }}</span>
                                {% endfor %}
                            </div>
                        {% endif %}

                        <!-- Action Buttons -->
                        <div class="profile-actions">
                            <a href="{{ path('app_welcome') }}" class="btn btn-outline-primary">
                                ← Back to Home
                            </a>
                            <a href="#" class="btn btn-primary">
                                Edit Profile
                            </a>
                        </div>
                    </div>
                </div>

                <!-- User ID Info -->
                <div class="alert alert-secondary mt-3" role="alert">
                    <small><strong>User ID:</strong> #{{ app.user.id }}</small>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
